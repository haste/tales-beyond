{
  "name": "Tales Beyond",
  "version": "0.25.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@floating-ui/dom": "^1.7.6",
    "@types/bun": "^1.3.11",
    "@types/chrome": "^0.1.38",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "adm-zip": "^0.5.16",
    "bootstrap": "^5.3.8",
    "chrome-webstore-upload-cli": "^3.5.0",
    "global-jsdom": "^29.0.0",
    "marked": "^17.0.4",
    "prettier": "3.8.1",
    "sass": "^1.98.0",
    "web-ext": "10.0.0"
  },
  "description": "Replaces D&D Beyond's digital dices with links to TaleSpire",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "bun run --bun scripts/build.js",
    "build:firefox": "bun run --bun scripts/build.js firefox",
    "build:chrome": "bun run --bun scripts/build.js chrome",
    "build:symbiote": "bun run --bun scripts/build.js symbiote",
    "package": "bun run package:chrome && bun run package:symbiote && bun run package:source",
    "package:chrome": "bun run --bun scripts/package-chrome.js",
    "package:symbiote": "bun run --bun scripts/package-symbiote.js",
    "package:source": "bun run --bun scripts/package-source.js",
    "watch": "bun run --bun --watch scripts/watch.js",
    "check": "bun run check:types && bun run check:biome && bun run check:prettier",
    "check:types": "tsgo --noEmit",
    "check:write": "bun run check:biome:write && bun run check:prettier:write",
    "check:biome": "bun biome check --error-on-warnings biome.json src/ scripts/ tests/",
    "check:biome:write": "bun check:biome --write",
    "check:prettier": "bun prettier --check src/scss/",
    "check:prettier:write": "bun check:prettier --write",
    "changelog:amo": "bun run scripts/changelog.js amo CHANGELOG.md",
    "changelog:modio": "bun run scripts/changelog.js modio CHANGELOG.md"
  },
  "type": "module"
}
